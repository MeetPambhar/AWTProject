datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  admin
  user
}

enum ResourceStatus {
  available
  occupied
  maintenance
  unavailable
}

enum ConditionStatus {
  good
  fair
  poor
  needs_repair
}

enum BookingStatus {
  pending
  approved
  rejected
  cancelled
  completed
}

enum Priority {
  low
  medium
  high
  critical
}

enum MaintenanceStatus {
  reported
  in_progress
  resolved
  closed
}

model User {
  id        Int      @id @default(autoincrement()) @map("user_id")
  name      String   @db.VarChar(100)
  email     String   @unique @db.VarChar(100)
  password  String   @db.VarChar(255)
  role      Role     @default(user)
  department String? @db.VarChar(100)
  phone     String?  @db.VarChar(20)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  isActive  Boolean  @default(true) @map("is_active")

  bookings         Booking[] @relation("UserBookings")
  approvedBookings Booking[] @relation("ApproverBookings")
  reportedMaintenance Maintenance[] @relation("ReporterMaintenance")

  @@map("users")
  @@index([email])
  @@index([role])
}

model Building {
  id           Int      @id @default(autoincrement()) @map("building_id")
  name         String   @map("building_name") @db.VarChar(100)
  location     String?  @db.VarChar(255)
  floors       Int?     @default(1)
  description  String?  @db.Text
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  resources    Resource[]

  @@map("buildings")
}

model ResourceType {
  id          Int      @id @default(autoincrement()) @map("type_id")
  name        String   @unique @map("type_name") @db.VarChar(100)
  description String?  @db.Text
  icon        String?  @db.VarChar(50)
  createdAt   DateTime @default(now()) @map("created_at")

  resources   Resource[]

  @@map("resource_types")
}

model Resource {
  id          Int            @id @default(autoincrement()) @map("resource_id")
  name        String         @map("resource_name") @db.VarChar(100)
  typeId      Int            @map("type_id")
  buildingId  Int            @map("building_id")
  floorNumber Int?           @map("floor_number")
  capacity    Int?
  status      ResourceStatus @default(available)
  description String?        @db.Text
  amenities   Json?
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  type        ResourceType   @relation(fields: [typeId], references: [id])
  building    Building       @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  
  facilities  Facility[]
  bookings    Booking[]
  maintenance Maintenance[]
  cupboards   Cupboard[]

  @@map("resources")
  @@index([status])
}

model Facility {
  id              Int             @id @default(autoincrement()) @map("facility_id")
  resourceId      Int             @map("resource_id")
  name            String          @map("facility_name") @db.VarChar(100)
  quantity        Int?            @default(1)
  conditionStatus ConditionStatus @default(good) @map("condition_status")
  lastChecked     DateTime?       @map("last_checked") @db.Date
  notes           String?         @db.Text

  resource        Resource        @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@map("facilities")
}

model Booking {
  id             Int           @id @default(autoincrement()) @map("booking_id")
  resourceId     Int           @map("resource_id")
  userId         Int           @map("user_id")
  bookingDate    DateTime      @map("booking_date") @db.Date
  startTime      DateTime      @map("start_time") @db.Time
  endTime        DateTime      @map("end_time") @db.Time
  purpose        String?       @db.VarChar(255)
  status         BookingStatus @default(pending)
  approverId     Int?          @map("approver_id")
  approvedAt     DateTime?     @map("approved_at")
  rejectionReason String?      @map("rejection_reason") @db.Text
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  resource       Resource      @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  user           User          @relation("UserBookings", fields: [userId], references: [id], onDelete: Cascade)
  approver       User?         @relation("ApproverBookings", fields: [approverId], references: [id])

  @@map("bookings")
  @@index([bookingDate])
  @@index([status])
}

model Maintenance {
  id               Int               @id @default(autoincrement()) @map("maintenance_id")
  resourceId       Int               @map("resource_id")
  reportedBy       Int               @map("reported_by")
  issueTitle       String            @map("issue_title") @db.VarChar(200)
  issueDescription String?           @map("issue_description") @db.Text
  priority         Priority          @default(medium)
  status           MaintenanceStatus @default(reported)
  assignedTo       String?           @map("assigned_to") @db.VarChar(100)
  resolutionNotes  String?           @map("resolution_notes") @db.Text
  reportedAt       DateTime          @default(now()) @map("reported_at")
  resolvedAt       DateTime?         @map("resolved_at")

  resource         Resource          @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  reporter         User              @relation("ReporterMaintenance", fields: [reportedBy], references: [id], onDelete: Cascade)

  @@map("maintenance")
  @@index([status])
}

model Cupboard {
  id              Int      @id @default(autoincrement()) @map("cupboard_id")
  resourceId      Int      @map("resource_id")
  name            String   @map("cupboard_name") @db.VarChar(100)
  locationInRoom  String?  @map("location_in_room") @db.VarChar(100)
  totalShelves    Int?     @default(1) @map("total_shelves")
  createdAt       DateTime @default(now()) @map("created_at")

  resource        Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  shelves         Shelf[]

  @@map("cupboards")
}

model Shelf {
  id             Int      @id @default(autoincrement()) @map("shelf_id")
  cupboardId     Int      @map("cupboard_id")
  shelfNumber    Int      @map("shelf_number")
  capacity       String?  @db.VarChar(50)
  currentItems   String?  @map("current_items") @db.Text
  isAvailable    Boolean? @default(true) @map("is_available")

  cupboard       Cupboard @relation(fields: [cupboardId], references: [id], onDelete: Cascade)

  @@map("shelves")
}
